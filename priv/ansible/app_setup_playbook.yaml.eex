- hosts: group_<%= @app_name %>
  environment:
    AWS_USE_DUALSTACK_ENDPOINT: true
  vars:
    app_name: "<%= @app_name %>"
    <%= if @port do %>app_port: <%= @port %><% end %>
  roles:
    - beam_linux_tuning
    - log_cleanup
    - pip3
    - awscli
    - ipv6
    <%= unless @no_prometheus do %>- prometheus_exporter
    <% end %>
    <%= unless @no_logging do %>- grafana_alloy
    <% end %>
    - save_ami
