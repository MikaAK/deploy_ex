#!/bin/bash
set -euo pipefail

SUBJECT="{{ letsencrypt_cert_subject }}"

# Short-lived IP certs expire in ~7 days; renew when <48h remain.
# Domain certs expire in 90 days; `certbot renew` is a no-op until <30d remain anyway.
if [ -f "/etc/letsencrypt/live/$SUBJECT/fullchain.pem" ]; then
    EXPIRY=$(openssl x509 -in "/etc/letsencrypt/live/$SUBJECT/fullchain.pem" -noout -enddate | cut -d= -f2)
    EXPIRY_EPOCH=$(date -d "$EXPIRY" +%s)
    CURRENT_EPOCH=$(date +%s)
    HOURS_LEFT=$(( (EXPIRY_EPOCH - CURRENT_EPOCH) / 3600 ))

    if [ $HOURS_LEFT -gt 48 ]; then
        echo "Certificate valid for $HOURS_LEFT hours. No renewal needed."
        exit 0
    fi
fi

# certbot renew uses per-cert stored config (DNS-01 or HTTP-01 standalone) from
# initial issuance, so the same script works in both domain and IP modes.
echo "Renewing certificate for $SUBJECT..."
certbot renew --non-interactive

# Restart services that terminate TLS so they pick up the new cert.
systemctl restart cfx-web || true
systemctl restart cfx-cms || true
systemctl restart cfx-hooks || true

echo "Certificate renewal complete"
