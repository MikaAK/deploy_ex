#!/bin/bash
set -euo pipefail

# `certbot renew` is rate-limit safe: it only renews certs that are inside their
# renewal window (ARI-aware, so it handles the short-lived QA certs correctly)
# and it renews certs that are already expired/overdue. The DNS-challenge and
# standalone-IP renewal parameters were persisted into the cert's renewal config
# at issuance time, so no flags need to be repeated here.
#
# QA nodes run this far more often than prod (see letsencrypt_renewal_oncalendar)
# because their certs are short-lived and the nodes are stopped/started often.
{% if letsencrypt_use_public_ip | bool %}
# Public-IP (standalone) path: the stored --pre-hook/--post-hook cycle nginx
# only when a cert is actually renewed.
certbot renew --non-interactive
{% else %}
# DNS-challenge path: restart the SSL-terminating services only when a cert was
# actually deployed, via --deploy-hook (runs once per renewed lineage).
certbot renew --non-interactive \
    --deploy-hook "systemctl restart cfx-web cfx-cms cfx-hooks"
{% endif %}
