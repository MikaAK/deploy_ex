#!/bin/bash
set -euo pipefail

# Boot-time certificate check. QA nodes are stopped/started often and run
# short-lived (~7-day) certs, so by the time a stopped node comes back its cert
# may be expired — which is exactly the ERR_CERT_DATE_INVALID the browser shows.
# Renew on boot (before the periodic timer would otherwise fire) so a freshly
# started node never serves an expired cert.

# Wait for the network (and DNS / IMDS) to be ready before contacting the CA.
sleep 30

exec /usr/local/bin/renew-certificates.sh
