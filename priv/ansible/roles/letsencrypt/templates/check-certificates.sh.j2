#!/bin/bash
set -euo pipefail

SUBJECT="{{ letsencrypt_cert_subject }}"

# Wait for network to be ready
sleep 30

if [ -f "/etc/letsencrypt/live/$SUBJECT/fullchain.pem" ]; then
    EXPIRY=$(openssl x509 -in "/etc/letsencrypt/live/$SUBJECT/fullchain.pem" -noout -enddate | cut -d= -f2)
    EXPIRY_EPOCH=$(date -d "$EXPIRY" +%s)
    CURRENT_EPOCH=$(date +%s)
    HOURS_LEFT=$(( (EXPIRY_EPOCH - CURRENT_EPOCH) / 3600 ))

    if [ $HOURS_LEFT -gt 0 ]; then
        echo "Certificate valid for $HOURS_LEFT hours"
        exit 0
    fi
fi

# Cert missing or expired — renewal uses per-cert stored config and works in both modes.
echo "Certificate missing or expired for $SUBJECT — running certbot renew"
certbot renew --non-interactive
